<idea-plugin require-restart="false">
    <id>com.brighterly.testlinks</id>
    <name>Tests Links</name>
    <vendor>Brighterly</vendor>
    <description><![CDATA[
        <p>
            Links PHP <b>Service</b> and <b>Controller</b> classes to their PHPUnit tests,
            scaffolds new test files on demand, and shows project-wide coverage in the status bar.
        </p>

        <h3>Gutter icon</h3>
        <ul>
            <li><b>Green</b> — at least one test file with ≥ 1 test method.</li>
            <li><b>Yellow</b> — test file exists but no test methods detected.</li>
            <li><b>Grey +</b> — no test file. Click to scaffold one.</li>
            <li>Tooltip shows the test method count, counting <code>function test*</code>, <code>#[Test]</code> attributes, and <code>@test</code> docblock tags.</li>
        </ul>

        <h3>Click actions</h3>
        <ul>
            <li><b>Open test</b> — single test file opens directly.</li>
            <li><b>Picker popup</b> — multiple test files (e.g. both <code>tests/Services/...</code> and <code>tests/Feature/Services/...</code>) show in a list.</li>
            <li><b>Create test</b> — grey <b>+</b> scaffolds <code>{ClassName}Test.php</code> at the mirrored path. Stub follows project conventions: <code>declare(strict_types=1)</code>, <code>extends TestCase</code>, <code>DatabaseTransactions</code> trait, AAA placeholder method.</li>
        </ul>

        <h3>Reverse navigation</h3>
        <ul>
            <li>Gutter icon on a test class jumps to the subject Service/Controller (uses PhpIndex).</li>
        </ul>

        <h3>Status bar widget</h3>
        <ul>
            <li>Shows <code>Tests 48% (72/150)</code> for Service + Controller coverage.</li>
            <li>Click for a breakdown, a rebuild action, and the first 30 uncovered class names.</li>
        </ul>

        <h3>Performance</h3>
        <ul>
            <li>Async index build at project open — typically 10–50 ms for 150 test files.</li>
            <li>Gutter rendering is a <code>ConcurrentHashMap</code> lookup with no disk I/O.</li>
            <li>VFS listener incrementally refreshes individual test and source files on save.</li>
        </ul>

        <h3>Scope</h3>
        <ul>
            <li>Classes under <code>app/Services/**</code> and <code>app/Http/Controllers/**</code>.</li>
            <li>Test files named <code>{ClassName}Test.php</code> anywhere inside <code>{projectRoot}/tests/</code>.</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Application-level settings -->
        <applicationService
            serviceImplementation="com.brighterly.testlinks.settings.TestsLinksSettings"/>

        <applicationConfigurable
            parentId="tools"
            instance="com.brighterly.testlinks.settings.TestsLinksConfigurable"
            id="com.brighterly.testlinks.settings"
            displayName="Tests Links"/>

        <!-- Project-level services -->
        <projectService
            serviceImplementation="com.brighterly.testlinks.service.TestIndexService"/>
        <projectService
            serviceImplementation="com.brighterly.testlinks.service.SourceIndexService"/>
        <projectService
            serviceImplementation="com.brighterly.testlinks.routes.RouteIndexService"/>
        <projectService
            serviceImplementation="com.brighterly.testlinks.coverage.CloverCoverageService"/>

        <!-- Rebuilds indexes on project open -->
        <postStartupActivity
            implementation="com.brighterly.testlinks.listener.TestIndexStartupActivity"/>

        <!-- Line marker: gutter icon near Service/Controller class declarations -->
        <codeInsight.lineMarkerProvider
            language="PHP"
            implementationClass="com.brighterly.testlinks.provider.TestFileLineMarkerProvider"/>

        <!-- Line marker: reverse navigation from test class to subject -->
        <codeInsight.lineMarkerProvider
            language="PHP"
            implementationClass="com.brighterly.testlinks.provider.ReverseTestLineMarkerProvider"/>

        <!-- Line marker: per-method coverage next to public Service/Controller methods -->
        <codeInsight.lineMarkerProvider
            language="PHP"
            implementationClass="com.brighterly.testlinks.provider.MethodTestLineMarkerProvider"/>

        <!-- Alt+Enter intention to create test file -->
        <intentionAction>
            <language>PHP</language>
            <className>com.brighterly.testlinks.intention.CreateTestIntention</className>
            <category>Tests Links</category>
        </intentionAction>

        <!-- Status bar widget: project-wide coverage % -->
        <statusBarWidgetFactory
            implementation="com.brighterly.testlinks.statusbar.CoverageStatusBarWidgetFactory"
            id="brighterly.testlinks.status"
            order="after Position"/>

        <!-- Notification group for file-creation results -->
        <notificationGroup
            id="Tests Links"
            displayType="BALLOON"/>

    </extensions>

    <applicationListeners>
        <!-- VFS listener: refresh index when test files or phpunit.xml change -->
        <listener
            class="com.brighterly.testlinks.listener.TestFileVfsListener"
            topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
    </applicationListeners>

    <actions>
        <action
            id="brighterly.testlinks.FindUntested"
            class="com.brighterly.testlinks.action.FindUntestedClassesAction"
            text="Find Untested Services &amp; Controllers"
            description="List all Services and Controllers without a corresponding test file">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action
            id="brighterly.testlinks.GoToTest"
            class="com.brighterly.testlinks.action.GoToTestAction"
            text="Go to Test (Tests Links)"
            description="Open the test file for the class under caret, or scaffold one if missing">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift T"/>
        </action>
    </actions>

</idea-plugin>
